DATABASE_URL=postgres://audioworld:audioworld@localhost:5434/audioworld
PORT=3001
UPLOAD_DIR=./uploads
CORS_ORIGIN=*
# REQUIRED in production (NODE_ENV=production): a strong random secret used to sign
# and verify JWTs. The server refuses to boot in production without it. Generate with:
#   openssl rand -base64 48
JWT_SECRET=
# Set to "production" on the server so security guards (JWT fail-fast) are enforced.
NODE_ENV=development
